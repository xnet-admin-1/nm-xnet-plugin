import sys, os, json, time, signal, subprocess, struct, socket
import dbus, dbus.service, dbus.mainloop.glib
from gi.repository import GLib

NM_VPN_SERVICE = "org.freedesktop.NetworkManager.zerotier"
NM_VPN_PATH = "/org/freedesktop/NetworkManager/VPN/Plugin"

INIT, STARTING, STARTED, STOPPING, STOPPED, FAILED = 1, 2, 3, 4, 5, 6

ZT = "/usr/sbin/zerotier-one"
ZT_HOME = "/var/lib/zerotier-one"


def ip2int(s):
    return struct.unpack("<I", socket.inet_aton(s))[0]


def zt_cli(args):
    return subprocess.run(
        [ZT, "-q", "-D" + ZT_HOME] + args,
        capture_output=True, text=True, timeout=5,
    )


def zt_json(args):
    r = subprocess.run(
        [ZT, "-q", "-j", "-D" + ZT_HOME] + args,
        capture_output=True, text=True, timeout=5,
    )
    return json.loads(r.stdout) if r.returncode == 0 else None


class ZeroTierVPN(dbus.service.Object):
    def __init__(self, bus, path):
        super().__init__(bus, path)
        self._state = INIT
        self._nwid = None
        self._timer = None
        self._connected = False

    def _set_state(self, s):
        if self._state != s:
            self._state = s
            self.StateChanged(s)

    # ── D-Bus methods ──

    @dbus.service.method("org.freedesktop.NetworkManager.VPN.Plugin",
                         in_signature="a{sa{sv}}", out_signature="")
    def Connect(self, connection):
        self._do_connect(connection)

    @dbus.service.method("org.freedesktop.NetworkManager.VPN.Plugin",
                         in_signature="a{sa{sv}}a{sa{sv}}", out_signature="")
    def ConnectInteractive(self, connection, details):
        self._do_connect(connection)

    @dbus.service.method("org.freedesktop.NetworkManager.VPN.Plugin",
                         in_signature="a{sa{sv}}", out_signature="s")
    def NeedSecrets(self, settings):
        return ""

    @dbus.service.method("org.freedesktop.NetworkManager.VPN.Plugin",
                         in_signature="", out_signature="")
    def Disconnect(self):
        self._set_state(STOPPING)
        if self._timer:
            GLib.source_remove(self._timer)
            self._timer = None
        self._connected = False
        self._set_state(STOPPED)

    @dbus.service.method("org.freedesktop.NetworkManager.VPN.Plugin",
                         in_signature="", out_signature="u")
    def State(self):
        return dbus.UInt32(self._state)

    # ── D-Bus signals ──

    @dbus.service.signal("org.freedesktop.NetworkManager.VPN.Plugin", signature="u")
    def StateChanged(self, state):
        pass

    @dbus.service.signal("org.freedesktop.NetworkManager.VPN.Plugin", signature="a{sv}")
    def Ip4Config(self, config):
        pass

    @dbus.service.signal("org.freedesktop.NetworkManager.VPN.Plugin", signature="u")
    def Failure(self, reason):
        pass

    # ── Logic ──

    def _do_connect(self, connection):
        try:
            vpn = connection.get("vpn", {})
            data = dict(vpn.get("data", {}))
            self._nwid = str(data.get("network-id", ""))

            if not self._nwid:
                self._set_state(FAILED)
                self.Failure(2)
                return

            # Check NM connection's never-default setting
            ipv4 = connection.get("ipv4", {})
            self._never_default = bool(ipv4.get("never-default", True))

            self._set_state(STARTING)

            # Ensure ZT daemon running
            try:
                r = zt_cli(["status"])
                if "ONLINE" not in r.stdout:
                    raise Exception("not online")
            except Exception:
                subprocess.Popen([ZT, ZT_HOME],
                                 stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                for _ in range(10):
                    time.sleep(1)
                    try:
                        if "ONLINE" in zt_cli(["status"]).stdout:
                            break
                    except Exception:
                        pass

            zt_cli(["join", self._nwid])

            self._connected = True
            self._timer = GLib.timeout_add(1000, self._poll)

        except Exception as e:
            print(f"Connect error: {e}", file=sys.stderr)
            self._set_state(FAILED)
            self.Failure(1)

    def _poll(self):
        if not self._connected:
            return False
        try:
            nets = zt_json(["listnetworks"])
            if not nets:
                return True
            for net in nets:
                if net.get("nwid") != self._nwid or net.get("status") != "OK":
                    continue
                dev = net.get("portDeviceName", "")
                addrs = net.get("assignedAddresses", [])
                zt_routes = net.get("routes", [])

                # Find first IPv4 address
                for addr in addrs:
                    if ":" in addr:
                        continue
                    ip_str, prefix = addr.split("/")

                    config = dbus.Dictionary({
                        "tundev": dbus.String(dev, variant_level=1),
                        "address": dbus.UInt32(ip2int(ip_str), variant_level=1),
                        "prefix": dbus.UInt32(int(prefix), variant_level=1),
                    }, signature="sv")

                    # Build routes from ZT network config
                    routes = dbus.Array([], signature="au")
                    for rt in zt_routes:
                        tgt = rt.get("target", "")
                        via = rt.get("via") or "0.0.0.0"
                        if ":" in tgt:
                            continue
                        if tgt == "0.0.0.0/0" and self._never_default:
                            continue
                        t_ip, t_pfx = tgt.split("/")
                        routes.append(
                            dbus.Array([
                                dbus.UInt32(ip2int(t_ip)),
                                dbus.UInt32(int(t_pfx)),
                                dbus.UInt32(ip2int(via)),
                                dbus.UInt32(0),  # metric
                            ], signature="u")
                        )

                    if routes:
                        config["routes"] = dbus.Array(routes, signature="au",
                                                      variant_level=1)

                    # Find default gateway from ZT routes
                    gw = None
                    for rt in zt_routes:
                        if rt.get("target") == "0.0.0.0/0" and rt.get("via"):
                            gw = rt["via"]
                            break
                    # NM requires a gateway; use ZT gateway or self
                    config["gateway"] = dbus.UInt32(
                        ip2int(gw if gw else ip_str), variant_level=1)

                    self.Ip4Config(config)
                    self._set_state(STARTED)
                    self._timer = None
                    return False

        except Exception as e:
            print(f"Poll error: {e}", file=sys.stderr)
        return True


def main():
    dbus.mainloop.glib.DBusGMainLoop(set_as_default=True)
    bus = dbus.SystemBus()
    bus_name = dbus.service.BusName(NM_VPN_SERVICE, bus)
    plugin = ZeroTierVPN(bus, NM_VPN_PATH)
    loop = GLib.MainLoop()
    signal.signal(signal.SIGTERM, lambda *_: loop.quit())
    signal.signal(signal.SIGINT, lambda *_: loop.quit())
    print("ZeroTier NM VPN plugin started", file=sys.stderr)
    loop.run()


if __name__ == "__main__":
    main()
