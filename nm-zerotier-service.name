[VPN Connection]
name=zerotier
service=org.freedesktop.NetworkManager.zerotier
program=/usr/libexec/nm-zerotier-service
supports-multiple-connections=false

[libnm]
plugin=libnm-vpn-plugin-zerotier-editor.so

[GNOME]
auth-dialog=/usr/libexec/nm-zerotier-auth-dialog
properties=libnm-vpn-plugin-zerotier-editor
supports-hints=true
